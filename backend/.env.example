# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/campussync

# Server
PORT=5000
NODE_ENV=development

# JWT (for existing auth — kept separate from QR signing secret below)
JWT_SECRET=replace_with_a_long_random_string

# QR ticket signing — HMAC secret used to sign/verify every ticket token.
# Must NEVER be exposed to the client. Rotate if leaked.
QR_SIGNING_SECRET=replace_with_a_different_long_random_string

# Resend (https://resend.com) — free tier: 3,000 emails/month, 100/day
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=CampusSync <onboarding@resend.dev>
